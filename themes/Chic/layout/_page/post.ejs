<div class="container">
    <%# toc %>
    <%if(theme.post_toc_enable && toc(page.content).length!==0){%>
        <%- partial('_partial/toc') %>
    <%}%>

    <%# article %>
    <article class="post-wrap">
        <header class="post-header">
            <h1 class="post-title"><%= page.title %></h1>
            <% if(theme.post_meta_enable){ %>
                <div class="post-meta">
                    <% if(page.categories.length!==0 && theme.post_category_enable){ %>
                        <span class="post-category">
                    分类:
                            <% page.categories.forEach(item=>{ %>
                                <a href="<%- url_for(item.path) %>"><%- item.name %></a>
                            <% }) %>
                        </span>
                    <% } %>
                    <% if(page.date && theme.post_date_enable){ %>
                        <span class="post-time">
                        日期: <a href="#"><%- date(page.date, theme.date_format)  %></a>
                        </span>
                    <% } %>
                    <% if(theme.post_author_enable && config.author){ %>
                        浏览: <a itemprop="author" rel="author" href="#"><span id="busuanzi_page_pv"></span></a>
                    <% } %>
                </div>
            <% } %>
        </header>

        <%# JSON-LD Structured Data - BlogPosting %>
<% var postDesc = page.description || (page.content ? page.content.replace(/<[^>]+>/g, '').substring(0, 150).replace(/\n/g, ' ').trim() + '...' : config.description || ''); %>
<script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "BlogPosting",
          "headline": "<%= page.title %>",
          "description": "<%= postDesc %>",
          "url": "<%= page.permalink %>",
          "datePublished": "<%= page.date %>",
          "dateModified": "<%= page.updated || page.date %>",
          "author": {
            "@type": "Person",
            "name": "<%= config.author || '' %>",
            "url": "<%= config.url %>"
          },
          "publisher": {
            "@type": "Organization",
            "name": "<%= config.title %>",
            "url": "<%= config.url %>",
            "logo": {
              "@type": "ImageObject",
              "url": "<%= config.url %><%- url_for(theme.avatar || theme.favicon) %>"
            }
          },
          <% if(page.index_img){ %>"image": "<%= page.index_img %>",<% } %>
          "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": "<%= page.permalink %>"
          },
          <% if(page.tags && page.tags.length){ %>
          "keywords": "<%= page.tags.map(t => t.name).join(', ') %>",
          <% } %>
          "articleBody": "<%= page.content.replace(/<[^>]+>/g, '').substring(0, 500) %>..."
        }
        </script>

        <div class="post-content">
            <%- page.content %>
        </div>

        <% if(theme.post_copyright_enable){ %>
            <section class="post-copyright">
                <% if(theme.post_copyright_author_enable){ %>
                    <p class="copyright-item">
                        <span>关注公众号:</span>
                        <span><%- config.author %></span>
                    </p>
                <% } %>
                <% if(theme.post_copyright_permalink_enable){ %>
                    <p class="copyright-item">
                        <span>链接:</span>
                        <span><a href="<%- page.permalink %>"><%- page.permalink %></a></span>
                    </p>
                <% } %>
                <% if(theme.post_copyright_slogan_enable){ %>
                     <p class="copyright-item">
                         <span>公告:</span>
                         <span><%- theme.post_copyright_slogan_text %></span>
                     </p>
                <% } %>

            </section>
        <% } %>
        <section class="post-tags">
            <div>
                <span>标签:</span>
                <span class="tag">
                    <% if(page.tags.length!==0){%>
                    <% page.tags.forEach(item=>{ %>
                        <a href="<%- url_for(item.path) %>"># <%- item.name %></a>
                    <% }) %>
                        <% } %>
                </span>
            </div>
            <div>
                <a href="javascript:window.history.back();">返回</a>
                <span>· </span>
                <a href="<%- config.root %>">首页</a>
            </div>
        </section>
        <section class="post-nav">
            <% if(post.prev){ %>
                <a class="prev" rel="prev" href="<%- url_for(post.prev.path)%>">上一篇</a>
            <% } %>
            <% if(post.next){ %>
            <a class="next" rel="next" href="<%- url_for(post.next.path)%>">下一篇</a>
            <% } %>
        </section>

        <% if(theme.giscus && theme.giscus.enable){ %>
        <section class="post-comment" id="comment" style="clear:both; margin-top: 2rem;">
            <div id="giscus"></div>
            <script src="https://giscus.app/client.js"
                    data-repo="<%= theme.giscus.repo %>"
                    data-repo-id="<%= theme.giscus.repoId %>"
                    data-category="<%= theme.giscus.category %>"
                    data-category-id="<%= theme.giscus.categoryId %>"
                    data-mapping="<%= theme.giscus.mapping %>"
                    data-reactions-enabled="<%= theme.giscus.reactionsEnabled %>"
                    data-emit-metadata="<%= theme.giscus.emitMetadata %>"
                    data-input-position="<%= theme.giscus.inputPosition %>"
                    data-theme="light"
                    data-lang="<%= theme.giscus.lang %>"
                    crossorigin="anonymous"
                    async>
            </script>
        </section>
        <% } %>

    </article>
</div>
